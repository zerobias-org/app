# Copy to `.env.development` for local dev (that file is git-ignored).
#
# Local dev talks to a REAL ZeroBias platform env for data + session. Because a
# browser on localhost can't share the platform's session cookie, local dev
# authenticates every API request with an API key instead (see docs/authentication.md).

# Turns on local-dev mode: enables the /api proxy and the API-key interceptor.
NEXT_PUBLIC_IS_LOCAL_DEV=true

# The platform origin whose session/portal you emulate locally (for redirects).
NEXT_PUBLIC_LOCAL_PORTAL_ORIGIN=http://localhost:3000/

# Where `/api/*` is proxied during `next dev`. Point at the platform env whose
# data you want locally: https://app.zerobias.com | https://qa.zerobias.com | https://uat.zerobias.com
NEXT_PUBLIC_DEV_API_ORIGIN=https://app.zerobias.com

# API key from that SAME platform env (user menu -> Create New API Key).
# Local dev only — added as an `Authorization: APIKey <key>` header. NEVER ships to prod.
NEXT_PUBLIC_API_KEY=your-platform-api-key
