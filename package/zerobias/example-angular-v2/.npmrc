# All ZeroBias scopes resolve from pkg.zerobias.org. @zerobias-com/@zerobias-org
# are the v2 platform SDKs + the Angular component library (ngx-library); @auditlogic
# carries the per-module clients. A single ZB_TOKEN authenticates them all — matching
# what CI provides (deploy.yml sets ZB_TOKEN).
#
# Get a ZB_TOKEN by creating an API key in the ZeroBias platform, then:
#   export ZB_TOKEN='<your api key>'
# before running `npm install`.
@zerobias-com:registry=https://pkg.zerobias.org
@zerobias-org:registry=https://pkg.zerobias.org
@auditlogic:registry=https://pkg.zerobias.org
//pkg.zerobias.org/:always-auth=true
//pkg.zerobias.org/:_authToken=${ZB_TOKEN}

# ngx-library and some SDKs publish peerDependency ranges that lag their real (v2)
# deps, so a strict install errors on the mismatch. legacy-peer-deps skips that
# check — CI and local both need it until the upstream peerDeps are corrected.
legacy-peer-deps=true
