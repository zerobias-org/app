{
  "name": "sme-mart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ci": "dotenv -e .env.local -e .env.dev -- next dev",
    "dev:qa": "dotenv -e .env.local -e .env.qa -- next dev",
    "dev:prod": "dotenv -e .env.local -e .env.prod -- next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx src/lib/db/seed.ts"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/material-nextjs": "^7.3.7",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.90.20",
    "@zerobias-com/zerobias-client": "^1.1.8",
    "axios": "^1.13.2",
    "buffer": "^6.0.3",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.563.0",
    "next": "^15.5.11",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sass": "^1.97.3",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "^15.5.9",
    "typescript": "^5",
    "webpack": "^5.104.1"
  },
  "overrides": {}
}
