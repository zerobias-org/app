# SME Mart Angular — Local Development Secrets
# Copy to .env.local and fill in your API keys.
# Generate keys from ZeroBias app in each environment.

# =============================================================================
# UAT — uat.zerobias.com — used by `npm run dev` (DEFAULT) / `npm run dev:uat`
# =============================================================================
ZEROBIAS_UAT_API_KEY=your-uat-api-key
ZEROBIAS_UAT_ORG_ID=your-uat-org-id

# =============================================================================
# DEV (CI) — ci.zerobias.com — DEPRECATED (being rebuilt with hydra)
# =============================================================================
API_KEY=your-ci-api-key
ZB_ORG_ID=your-ci-org-id

# =============================================================================
# QA — qa.zerobias.com — used by `npm run dev:qa`
# =============================================================================
ZEROBIAS_QA_API_KEY=your-qa-api-key
ZEROBIAS_QA_ORG_ID=your-qa-org-id

# =============================================================================
# PROD — app.zerobias.com — used by `npm run dev:prod`
# =============================================================================
ZEROBIAS_PROD_API_KEY=your-prod-api-key
ZEROBIAS_PROD_ORG_ID=your-prod-org-id
