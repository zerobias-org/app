# SME Mart E2E — environment variables
# Copy to e2e/.env and fill in values. This file is committed, e2e/.env is not.
#
# The auth fixture reads these vars to inject the dana-org-id cookie so the
# in-browser SDK can resolve the org context. API authentication (API key) is
# still handled by the Angular dev server proxy via .env.local — E2E does NOT
# need the API key at the browser level.

# Target URL for tests (Angular dev server default is 4200)
BASE_URL=http://localhost:4200

# UAT org ID — used to inject dana-org-id cookie before each test.
# Must match ZEROBIAS_UAT_ORG_ID in .env.local so cookie and proxy agree.
ZEROBIAS_UAT_ORG_ID=

# Optional fallback (matches dev proxy env var naming)
# ZB_ORG_ID=
