src/environments/environment.neon.ts

# Husky hooks (tracked at git root, not here)
.husky/

# ESLint cache (lint-staged --cache, see .lintstagedrc.json)
.eslintcache

# Claude project files (local-only)
.claude/.obsidian/
.claude/diagrams/
.claude/proposals/
.claude/design/
.claude/plans-archive/
